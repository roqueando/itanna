# Itanna Environment Variables
# Auto-detected by the VSCode adapter, but can be set explicitly.

# Python virtual environment (auto-detected from Poetry)
# VIRTUAL_ENV=${workspaceFolder}/.venv

# Python path for Jupyter and tools
# PYTHONPATH=${workspaceFolder}:${workspaceFolder}/electrical:${workspaceFolder}/itanna

# Itanna project root (used by VSCode extension to find templates)
# Uncomment and set to the itanna project root if opening VSCode from a different directory
# ITANNA_ROOT=/Users/roqueando/projects/itanna
