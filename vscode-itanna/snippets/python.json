{
  "Buck Converter Design": {
    "prefix": "itanna-buck",
    "body": [
      "from electrical.converter.buck import design_buck",
      "",
      "# ── Buck converter design parameters ──",
      "vin    = ${1:12}      # Input voltage (V)",
      "vout   = ${2:3.3}     # Output voltage (V)",
      "iout   = ${3:2.0}     # Output current (A)",
      "fsw    = ${4:300e3} # Switching frequency (Hz)",
      "vripple = ${5:0.01} # Output voltage ripple (V)",
      "",
      "# ── Run design calculation ──",
      "results = design_buck(",
      "    vin=vin, vout=vout, iout=iout,",
      "    fsw=fsw, vripple=vripple,",
      "    il_ripple_pct=${6:0.30},",
      ")",
      "",
      "# ── Pretty-print results ──",
      "print(\"─\" * 50)",
      "print(\"  BUCK CONVERTER — Component Selection\")",
      "print(\"─\" * 50)",
      "for k, v in results.items():",
      "    if isinstance(v, float):",
      "        print(f\"  {k:25s}: {v:.4e}\")",
      "    else:",
      "        print(f\"  {k:25s}: {v}\")",
      "print(\"─\" * 50)"
    ],
    "description": "Insert a buck converter design calculation snippet"
  },
